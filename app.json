{
  "expo": {
    "name": "courries",
    "slug": "courriesRiderApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "courriesapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1969fe",
          "sounds": [
            "./assets/sounds/ringtone.mp3"
          ]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0000FF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.723785150509-ag0k4lgls2qaq78enj48brdepmlgq2mj"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-secure-store", 
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show your position on the map and select pickup/dropoff locations.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to show your position on the map and select pickup/dropoff locations.",
        "NSLocationAlwaysUsageDescription": "This app uses your location to show your position on the map and select pickup/dropoff locations.",
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.smhosdeveloper.courriesRiderApp",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.smhosdeveloper.courriesRiderApp",
      "adaptiveIcon": {
        "backgroundColor": "#0000FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBqEuFtu8fOZmvTQFPRvFMzyEp15Xpf0fo"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.smhosdeveloper.courriesRiderApp.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.smhosdeveloper.courriesRiderApp.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "cfd2df9b-c64f-4420-8523-80cceb224e6e"
      },
      "router": {}
    }
  }
}